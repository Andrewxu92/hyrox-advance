# HYROX Advance Production Environment Variables
# ================================================
# 复制此文件为 .env.local 并填入实际值，或在 Vercel Dashboard 中配置

# 服务器配置
NODE_ENV=production
PORT=5001

# AI API Configuration (选择其中一个配置)
# ================================================

# Option 1: OpenAI (国际用户)
# OPENAI_API_KEY=sk-your-openai-api-key-here
# OPENAI_BASE_URL=https://api.openai.com/v1

# Option 2: DashScope (阿里云) - 推荐中国用户使用
# DASHSCOPE_API_KEY=your-dashscope-api-key-here
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Option 3: 其他兼容 OpenAI API 的服务
# CUSTOM_API_KEY=your-api-key
# CUSTOM_BASE_URL=https://your-api-endpoint.com/v1

# 数据库配置 (可选)
# ================================================
# 生产环境使用内存数据库或配置外部数据库
# DATABASE_PATH=/tmp/hyrox.db

# 前端 API 地址 (Vercel 自动注入)
# VITE_API_URL 在构建时由 Vercel 环境变量提供

{
  "name": "hyrox-advance",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development tsx server/index.ts",
    "dev:client": "cd client && pnpm run dev",
    "build": "pnpm install && pnpm run build:server && cd client && pnpm install && pnpm run build",
    "build:client": "cd client && pnpm run build",
    "build:server": "esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "start": "NODE_ENV=production node dist/index.js",
    "check": "tsc",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "db:init": "tsx server/db/init.ts",
    "db:export": "tsx server/db/export-cli.ts"
  },
  "dependencies": {
    "@types/node": "20.16.11",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.6.2",
    "cheerio": "^1.2.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.39.3",
    "drizzle-zod": "^0.7.0",
    "express": "^4.22.1",
    "express-rate-limit": "^8.3.1",
    "jsonwebtoken": "^9.0.2",
    "openai": "^4.104.0",
    "puppeteer": "^24.37.5",
    "sql.js": "^1.14.1",
    "tsx": "^4.19.1",
    "typescript": "5.6.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.19",
    "@types/express": "4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@vercel/node": "^5.6.15",
    "@vitest/coverage-v8": "^1.6.1",
    "esbuild": "^0.25.0",
    "prebuild-install": "^7.1.2",
    "vitest": "^1.6.1"
  }
}

# HYROX Advance Environment Variables
# 复制此文件为 .env 并按需修改

# 服务端口（需与 client/vite.config.ts 中 proxy 的 target 端口一致）
PORT=5000
NODE_ENV=development

# AI API（分析/训练计划必填其一）
# Option 1: OpenAI
# OPENAI_API_KEY=sk-your-openai-api-key-here

# Option 2: DashScope (阿里云，国内推荐)
# DASHSCOPE_API_KEY=your-dashscope-api-key-here

# 数据库（可选，默认 ./data/hyrox.db）
# DATABASE_PATH=./data/hyrox.db

# 生产环境 CORS 白名单（逗号分隔，不设则允许任意来源）
# ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# 限流（可选）：分析/爬虫 API 的请求限制
# RATE_LIMIT_ANALYSIS_MAX=20
# RATE_LIMIT_ANALYSIS_WINDOW_MS=60000
# RATE_LIMIT_SCRAPE_MAX=10
# RATE_LIMIT_SCRAPE_WINDOW_MS=60000

# --- 前端 client/（可选，见 README）---
# 本地开发留空，使用 Vite proxy；前后端分离部署时再填后端根 URL
# VITE_API_URL=https://your-api.example.com
